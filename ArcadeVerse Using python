import random

score = 0

while True:
target = random.randint(1, 5)

try:
    guess = int(input("Guess a number (1-5, 0 to quit): "))

    if guess == 0:
        break

    if guess == target:
        score += 10
        print("Correct! +10")
    else:
        print(f"Wrong! Number was {target}")

    print("Score:", score)

except ValueError:
    print("Enter a valid number.")
